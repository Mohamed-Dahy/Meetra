# =============================================================================
# Meetra — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# --- Shared (Backend + Chatbot both read this) ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Main
GEMINI_API_KEY=

# --- Backend + Chatbot ---
JWT_SECRET=
PORT=5000
RESEND_API_KEY=
EMAIL_FROM=Meetra <onboarding@yourdomain.com>
EMAIL_USER=
EMAIL_PASSWORD=
ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# --- API versioning note ---
# The backend serves both /meetra/v1/* (current) and /meetra/* (legacy compat).
# docker-compose.yml passes VITE_API_BASE_URL=http://localhost:5000/meetra/v1
# to the frontend build. Update to your real domain for production deploys.
