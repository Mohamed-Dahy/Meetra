# =============================================================================
# Meetra — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# --- Shared (Backend + Chatbot both read this) ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Main
GEMINI_API_KEY=

# --- Backend only ---
JWT_SECRET=
PORT=5000
RESEND_API_KEY=
EMAIL_USER=
EMAIL_PASSWORD=
